# ══════════════════════════════════════════════════════════════
#  BIAGIOVISUALS — Root .htaccess  (XAMPP · Apache 2.4)
# ══════════════════════════════════════════════════════════════

Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Adatta RewriteBase al path del progetto su XAMPP
    RewriteBase /biagiovisuals/

    # ── Blocca file sensibili ─────────────────────────────────
    RewriteRule ^\.env$                 - [F,L]
    RewriteRule ^\.git(/|$)             - [F,L]
    RewriteRule ^server(/|$)            - [F,L]
    RewriteRule ^data(/|$)              - [F,L]
    RewriteRule ^node_modules(/|$)      - [F,L]

    # ── API PHP → passano direttamente ───────────────────────
    RewriteRule ^api/                   - [L]

    # ── Uploads → passano direttamente ──────────────────────
    RewriteRule ^uploads/               - [L]

    # ── Admin shortcut ───────────────────────────────────────
    RewriteRule ^admin/?$               public/admin.html [L]

    # ── File statici in public/ già esistenti → passano ─────
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^                       - [L]

    # ── Risorse CSS/JS/assets da public/ ────────────────────
    RewriteRule ^(css|js|assets|pages)/(.+)$   public/$1/$2 [L]

    # ── Tutto il resto → public/index.html ──────────────────
    RewriteRule ^(.*)$                  public/index.html [L]
</IfModule>

# ── PHP upload limits ─────────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 30M
    php_value post_max_size 32M
    php_value max_execution_time 60
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 30M
    php_value post_max_size 32M
    php_value max_execution_time 60
</IfModule>

# ── Security headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
