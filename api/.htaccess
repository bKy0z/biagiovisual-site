# ── BIAGIOVISUALS — API folder protection ──────────────────────────
# Blocca accesso diretto ai file di supporto (non endpoint)

Order Allow,Deny
Allow from all

# Blocca accesso diretto ai file non-endpoint
<FilesMatch "^(auth|config)\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Nessuna directory listing
Options -Indexes

# Header di sicurezza
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
Header always set Referrer-Policy "strict-origin-when-cross-origin"